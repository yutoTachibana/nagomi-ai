# ----------------------------------------------------------------------
# Database (SQLite)
# ----------------------------------------------------------------------
# ローカル開発: Docker 不要。SQLite ファイルが自動作成されます
DATABASE_PATH=./data/komorebi.db

# ----------------------------------------------------------------------
# Auth.js
# ----------------------------------------------------------------------
# openssl rand -base64 32 で生成
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# X (Twitter) OAuth (https://developer.x.com/en/portal)
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# ----------------------------------------------------------------------
# Anthropic (Claude)
# ----------------------------------------------------------------------
# https://console.anthropic.com/ で発行
ANTHROPIC_API_KEY=
# 使用モデル (CLAUDE.md で固定)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------
# アプリ設定
# ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 機能フラグ
# 暗号化を有効にする (Phase 2 で true へ)
NEXT_PUBLIC_FEATURE_E2E_ENCRYPTION=false

# ----------------------------------------------------------------------
# SMTP (メール送信)
# ----------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=こもれび <noreply@example.com>
