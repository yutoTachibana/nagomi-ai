# ----------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------
# ローカル開発: docker compose up -d で起動
DATABASE_URL=postgresql://komorebi:komorebi_dev@localhost:5432/komorebi

# ----------------------------------------------------------------------
# Auth.js
# ----------------------------------------------------------------------
# openssl rand -base64 32 で生成
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ----------------------------------------------------------------------
# Anthropic (Claude)
# ----------------------------------------------------------------------
# https://console.anthropic.com/ で発行
ANTHROPIC_API_KEY=
# 使用モデル (CLAUDE.md で固定)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------
# アプリ設定
# ----------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 機能フラグ
# 暗号化を有効にする (Phase 2 で true へ)
NEXT_PUBLIC_FEATURE_E2E_ENCRYPTION=false

# ----------------------------------------------------------------------
# SMTP (メール送信)
# ----------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=こもれび <noreply@example.com>
