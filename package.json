    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "libsodium-wrappers": "^0.7.15",
    "lucide-react": "^0.460.0",
    "next": "15.0.3",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.7",
    "postgres": "^3.4.9",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106",
